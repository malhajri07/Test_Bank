# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Configuration
DB_NAME=testbank_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Stripe Configuration (for payments)
STRIPE_PUBLIC_KEY=your-stripe-public-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Google OAuth (django-allauth - add Social Application in /admin/socialaccount/socialapp/)
# Create app at https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Tap Payments (MEA - optional; test keys from https://developers.tap.company/reference/testing-keys)
# Do not commit real keys — copy from Tap dashboard into your local .env only.
TAP_PUBLISHABLE_KEY=your-tap-publishable-key
TAP_SECRET_KEY=your-tap-secret-key
TAP_MERCHANT_ID=your-tap-merchant-id
TAP_CURRENCY=USD

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@examstellar.com

# NPM Binary Path (for Tailwind CSS)
NPM_BIN_PATH=/usr/bin/npm

# Docker-specific settings
CREATE_SUPERUSER=false
WEB_PORT=8000
NGINX_PORT=80

