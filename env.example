# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Configuration
DB_NAME=testbank_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Paylink Payment Gateway
# Testing: https://restpilot.paylink.sa  Production: https://restapi.paylink.sa
PAYLINK_BASE_URL=https://restpilot.paylink.sa
PAYLINK_APP_ID=your-paylink-app-id
PAYLINK_SECRET_KEY=your-paylink-secret-key
PAYLINK_CURRENCY=SAR

# Google OAuth (django-allauth - add Social Application in /admin/socialaccount/socialapp/)
# Create app at https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@examstellar.com

# NPM Binary Path (for Tailwind CSS)
NPM_BIN_PATH=/usr/bin/npm

# Docker-specific settings
CREATE_SUPERUSER=false
WEB_PORT=8000
NGINX_PORT=80

